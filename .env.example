# Core provider/API config
TOGETHER_API_KEY=replace_me
TOGETHER_BASE_URL=https://api.together.xyz

# Router controls
ROUTER_MODE=heuristic
AB_SPLIT_RATIO=0.10
BUDGET_DEFAULT=balanced

# Context manager controls
CONTEXT_WINDOW_SIZE=5
CONTEXT_MAX_TOKENS=4000
SUMMARIZER_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Models and thresholds
SMALL_MODEL=mistralai/Mistral-7B-Instruct-v0.2
MEDIUM_MODEL=meta-llama/Llama-2-13b-chat-hf
LARGE_MODEL=meta-llama/Llama-2-70b-chat-hf
MEDIUM_THRESHOLD=0.35
LARGE_THRESHOLD=0.70

# API + logging
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Persistence
SQLITE_PATH=./data/router.db
